{
  "name": "askpdf",
  "version": "1.0.0",
  "description": "RAG-powered PDF document Q&A system with async processing, Gemini embeddings, MongoDB, Redis, and React.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "server": "node backend/src/server.js",
    "worker": "node backend/src/worker.js",
    "client": "vite --host 0.0.0.0 --configLoader runner",
    "preview": "vite preview --host 0.0.0.0 --port 5173 --configLoader runner",
    "build": "vite build --configLoader runner",
    "dev": "npm run build && npm run preview",
    "dev:all": "concurrently \"npm run server\" \"npm run worker\" \"npm run client\"",
    "lint": "eslint .",
    "start": "npm run server"
  },
  "dependencies": {
    "@google/genai": "^1.11.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.0",
    "uuid": "^11.0.5",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tailwindcss": "^4.3.3"
  }
}
