GEMINI_API_KEY=your_gemini_api_key_here
# Local MongoDB, Atlas SRV, and Atlas standard non-SRV strings are all supported.
# Example local: mongodb://127.0.0.1:27017/askpdf
# Example Atlas SRV: mongodb+srv://user:password@cluster.mongodb.net/askpdf?retryWrites=true&w=majority
# Example Atlas standard: mongodb://host1:27017,host2:27017,host3:27017/askpdf?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/askpdf
REDIS_URL=redis://127.0.0.1:6379
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads
QUEUE_NAME=askpdf:jobs
JOB_STALE_MINUTES=30
SIMILARITY_THRESHOLD=0.55
TOP_K=5

# Frontend (Vite) — required at build/dev time for API + SSE calls
VITE_API_URL=http://localhost:4000
